{
  "name": "@curieai/curieai",
  "version": "0.1.3",
  "description": "The official JavaScript/TypeScript SDK for Curie — inference infrastructure for scientific AI",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "biology",
    "chemistry",
    "physics",
    "AI",
    "protein",
    "inference",
    "scientific"
  ],
  "license": "MIT",
  "author": "Curie <hello@curie.sh>",
  "homepage": "https://curie.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/curie-ai/curie"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {}
}
